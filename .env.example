# 画像から食品を認識するには、次のどちらか一方を設定してください。

# 【無料枠あり】Google Gemini（推奨・無料で試しやすい）
# https://aistudio.google.com/apikey で取得
# GEMINI_API_KEY=

# OpenAI（有料・クレジット必要）
# https://platform.openai.com/api-keys で取得
# OPENAI_API_KEY=sk-...

# Lark (Feishu) Webhook URL (エラー通知、ユーザー登録・ログイン通知用)
# LARK_ERROR_WEBHOOK_URL=https://open.larksuite.com/open-apis/bot/v2/hook/xxx-error
# LARK_AUTH_WEBHOOK_URL=https://open.larksuite.com/open-apis/bot/v2/hook/xxx-auth

# Clerk Webhook Secret (ユーザー登録・ログイン受信検証用)
# CLERK_WEBHOOK_SECRET=whsec_...

# Google Search Console (所有権確認用)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=sQIryQWe8QfEbcpy5MRWQJfk603ogxuaEe3d0PF2Yfk

# Phase 1 日次計測・Discord朝報
# DISCORD_REPORT_WEBHOOK_URL=https://discord.com/api/webhooks/...
# CRON_SECRET=
# GA4_PROPERTY_ID=
# GSC_SITE_URL=https://www.log-eats.com/
# GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=

# product_events移行をローカルから実行する場合
# Vercel Storage連携時に自動設定されるPOSTGRES_URLを使用します。
# LINE Messaging API & Bot連携設定
# NEXT_PUBLIC_LINE_CONNECT_URL=https://lin.ee/xxxxxx
# NEXT_PUBLIC_LINE_FRIEND_URL=https://lin.ee/xxxxxx
# LINE_CHANNEL_SECRET=
# LINE_CHANNEL_ACCESS_TOKEN=
